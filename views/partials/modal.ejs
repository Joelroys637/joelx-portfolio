  <!-- Get in Touch Modal -->
  <div id="get-in-touch-modal" class="hidden fixed inset-0 z-[100] bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 font-body">
    <div class="bg-[#111111] border border-white/10 rounded-2xl w-full max-w-lg p-8 relative shadow-2xl overflow-y-auto max-h-[90vh]">
      <!-- Close Button -->
      <button id="close-modal" class="absolute top-6 right-6 w-8 h-8 flex items-center justify-center rounded border border-white/10 text-gray-400 hover:text-white hover:border-white/30 transition-colors bg-[#1a1a1a]">
        <span class="material-symbols-outlined text-sm">close</span>
      </button>
      
      <h3 class="font-headline italic text-white text-3xl mb-1">Start Your <span class="text-[#d2a373]">Project</span></h3>
      <p class="font-body text-gray-400 text-sm mb-6 pb-6 border-b border-white/10 leading-relaxed">Fill out the details below and let's create something amazing together.</p>
      
      <form id="inquiry-form" class="space-y-4">
        <!-- Package & Price (Readonly display) -->
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] uppercase text-gray-500 tracking-widest mb-1 font-label">Package</label>
            <input type="text" id="modal-package" name="package" readonly class="w-full bg-[#1a1a1a] border border-white/5 rounded-md px-4 py-2.5 text-[#d2a373] focus:outline-none opacity-80 cursor-not-allowed font-body text-sm">
          </div>
          <div>
            <label class="block text-[10px] uppercase text-gray-500 tracking-widest mb-1 font-label">Price (₹)</label>
            <input type="text" id="modal-price" name="price" readonly class="w-full bg-[#1a1a1a] border border-white/5 rounded-md px-4 py-2.5 text-[#d2a373] focus:outline-none opacity-80 cursor-not-allowed font-body text-sm">
          </div>
        </div>
        
        <!-- Name & Email -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] uppercase text-gray-500 tracking-widest mb-1 font-label">Your Name <span class="text-[#d2a373]">*</span></label>
            <input type="text" id="modal-name" name="name" required placeholder="Your name" class="w-full bg-[#111111] border border-white/10 rounded-md px-4 py-2.5 text-gray-300 placeholder-gray-600 focus:outline-none focus:border-[#d2a373] focus:ring-1 focus:ring-[#d2a373] transition-all font-body text-sm">
          </div>
          <div>
            <label class="block text-[10px] uppercase text-gray-500 tracking-widest mb-1 font-label">Email <span class="text-[#d2a373]">*</span></label>
            <input type="email" id="modal-email" name="email" required placeholder="you@company.com" class="w-full bg-[#111111] border border-white/10 rounded-md px-4 py-2.5 text-gray-300 placeholder-gray-600 focus:outline-none focus:border-[#d2a373] focus:ring-1 focus:ring-[#d2a373] transition-all font-body text-sm">
          </div>
        </div>
        
        <!-- Phone & OrgType -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] uppercase text-gray-500 tracking-widest mb-1 font-label">Phone <span class="text-[#d2a373]">*</span></label>
            <input type="tel" id="modal-phone" name="phone" required placeholder="+91 00000 00000" class="w-full bg-[#111111] border border-white/10 rounded-md px-4 py-2.5 text-gray-300 placeholder-gray-600 focus:outline-none focus:border-[#d2a373] focus:ring-1 focus:ring-[#d2a373] transition-all font-body text-sm">
          </div>
          <div>
            <label class="block text-[10px] uppercase text-gray-500 tracking-widest mb-1 font-label">Organization <span class="text-[#d2a373]">*</span></label>
            <div class="relative">
              <select id="modal-orgType" name="orgType" required class="w-full bg-[#111111] border border-white/10 rounded-md px-4 py-2.5 text-white placeholder-gray-600 focus:outline-none focus:border-[#d2a373] focus:ring-1 focus:ring-[#d2a373] transition-all appearance-none font-body text-sm">
                <option value="" disabled selected>Select Organization</option>
                <option value="Educational Institutions">Educational Institutions</option>
                <option value="Healthcare Organizations">Healthcare Organizations</option>
                <option value="Retail Businesses">Retail Businesses</option>
                <option value="Manufacturing Companies">Manufacturing Companies</option>
                <option value="Government Organizations">Government Organizations</option>
                <option value="Financial Institutions">Financial Institutions</option>
                <option value="Real Estate Companies">Real Estate Companies</option>
                <option value="Logistics & Transportation">Logistics & Transportation</option>
                <option value="Hospitality & Tourism">Hospitality & Tourism</option>
                <option value="Small & Medium Enterprises (SMEs)">Small & Medium Enterprises (SMEs)</option>
                <option value="Others">Others</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-400">
                <span class="material-symbols-outlined text-sm">expand_more</span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Comment -->
        <div>
          <label class="block text-[10px] uppercase text-gray-500 tracking-widest mb-1 font-label">How can we help you? <span class="text-[#d2a373]">*</span></label>
          <textarea id="modal-comment" name="comment" required rows="2" placeholder="Briefly describe what you need." class="w-full bg-[#111111] border border-white/10 rounded-md px-4 py-2.5 text-gray-300 placeholder-gray-600 focus:outline-none focus:border-[#d2a373] focus:ring-1 focus:ring-[#d2a373] transition-all font-body text-sm"></textarea>
        </div>
        
        <button type="submit" id="submit-inquiry-btn" class="w-full py-3.5 mt-2 rounded-md bg-gradient-to-r from-[#d2a373] to-[#d2a373] text-[#0e0e0e] font-bold tracking-widest hover:scale-[1.02] transition-transform shadow-lg shadow-[#d2a373]/20 flex justify-center items-center gap-2">
          Submit Inquiry
        </button>

        <div id="modal-success-msg" class="hidden text-center text-[#25D366] font-body text-sm mt-3 p-2 bg-[#25D366]/10 rounded border border-[#25D366]/20">
          Thank you! We have received your inquiry.
        </div>
        <div id="modal-error-msg" class="hidden text-center text-red-500 font-body text-sm mt-3 p-2 bg-red-500/10 rounded border border-red-500/20">
          Failed to submit. Please try again.
        </div>
      </form>
    </div>
  </div>

  <script>
    function openGetInTouchModal(pkg, price) {
      try {
        const modal = document.getElementById('get-in-touch-modal');
        const modalPackage = document.getElementById('modal-package');
        const modalPrice = document.getElementById('modal-price');
        
        if (modal) {
          if (modalPackage) modalPackage.value = pkg || 'Custom Quote';
          if (modalPrice) modalPrice.value = price || 'TBD';
          
          modal.classList.remove('hidden');
          modal.style.display = 'flex';
          document.body.style.overflow = 'hidden';
        }
      } catch (err) {
        console.error("Error opening modal:", err);
      }
    }
    
    document.addEventListener('DOMContentLoaded', () => {
      const modal = document.getElementById('get-in-touch-modal');
      const closeBtn = document.getElementById('close-modal');
      const form = document.getElementById('inquiry-form');
      const submitBtn = document.getElementById('submit-inquiry-btn');
      const successMsg = document.getElementById('modal-success-msg');
      const errorMsg = document.getElementById('modal-error-msg');

      if (modal && closeBtn) {
        closeBtn.addEventListener('click', () => {
          modal.style.display = 'none';
          modal.classList.add('hidden');
          document.body.style.overflow = 'auto';
          form.reset();
          successMsg.classList.add('hidden');
          errorMsg.classList.add('hidden');
        });
        
        modal.addEventListener('click', (e) => {
          if (e.target === modal) {
            closeBtn.click();
          }
        });
      }

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          submitBtn.disabled = true;
          const originalText = submitBtn.innerHTML;
          submitBtn.innerHTML = 'Submitting...';
          successMsg.classList.add('hidden');
          errorMsg.classList.add('hidden');
          
          const formData = new FormData(form);
          const data = Object.fromEntries(formData.entries());
          
          try {
            const response = await fetch('/api/inquiries', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data)
            });
            
            if (response.ok) {
              successMsg.classList.remove('hidden');
              form.reset();
              setTimeout(() => { closeBtn.click(); }, 3000);
            } else {
              errorMsg.classList.remove('hidden');
            }
          } catch (err) {
            console.error(err);
            errorMsg.classList.remove('hidden');
          } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
          }
        });
      }
    });
  </script>
