<!DOCTYPE html>
<html class="dark" lang="en">
<head>
  <%- include('../partials/head') %>
</head>
<body class="bg-[#0e0e0e] text-white font-body selection:bg-primary/30 selection:text-primary overflow-x-hidden">

  <%- include('../partials/header') %>

<!-- Main Content Canvas -->
<main class="pt-28 pb-32 max-w-2xl mx-auto px-6 relative">
  <div class="absolute inset-0 bg-[#f9c591]/5 rounded-full blur-[100px] transform scale-150 -z-10"></div>
  <div class="bg-[#131313] border border-white/10 rounded-2xl w-full p-8 relative shadow-2xl">
    <h3 class="font-headline italic text-4xl text-white mb-2 text-center">Start Your <span class="text-primary">Journey</span></h3>
    <p class="text-on-surface-variant text-center mb-8">Fill out the details below and we will get back to you shortly.</p>
    
    <form id="inquiry-form" class="space-y-5">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-label text-gray-400 mb-1">Package</label>
          <input type="text" id="page-package" name="package" readonly class="w-full bg-[#0e0e0e] border border-white/5 rounded-lg px-4 py-3 text-[#f9c591] focus:outline-none opacity-80 cursor-not-allowed">
        </div>
        <div>
          <label class="block text-xs font-label text-gray-400 mb-1">Price (₹)</label>
          <input type="text" id="page-price" name="price" readonly class="w-full bg-[#0e0e0e] border border-white/5 rounded-lg px-4 py-3 text-[#f9c591] focus:outline-none opacity-80 cursor-not-allowed">
        </div>
      </div>
      
      <div>
        <label class="block text-xs font-label text-gray-400 mb-1">Name</label>
        <input type="text" id="page-name" name="name" required placeholder="John Doe" class="w-full bg-[#0e0e0e] border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[#f9c591] transition-colors">
      </div>
      
      <div>
        <label class="block text-xs font-label text-gray-400 mb-1">Phone Number</label>
        <input type="tel" id="page-phone" name="phone" required placeholder="+91 00000 00000" class="w-full bg-[#0e0e0e] border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[#f9c591] transition-colors">
      </div>
      
      <div>
        <label class="block text-xs font-label text-gray-400 mb-1">Email</label>
        <input type="email" id="page-email" name="email" required placeholder="john@example.com" class="w-full bg-[#0e0e0e] border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[#f9c591] transition-colors">
      </div>

      <div>
        <label class="block text-xs font-label text-gray-400 mb-1">Organization Type</label>
        <select id="page-org-type" name="orgType" class="w-full bg-[#0e0e0e] border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[#f9c591] transition-colors appearance-none">
          <option value="Educational Institutions">Educational Institutions</option>
          <option value="Healthcare Organizations">Healthcare Organizations</option>
          <option value="Retail Businesses">Retail Businesses</option>
          <option value="Manufacturing Companies">Manufacturing Companies</option>
          <option value="Government Organizations">Government Organizations</option>
          <option value="Financial Institutions">Financial Institutions</option>
          <option value="Real Estate Companies">Real Estate Companies</option>
          <option value="Logistics & Transportation Companies">Logistics & Transportation Companies</option>
          <option value="Hospitality & Tourism Businesses">Hospitality & Tourism Businesses</option>
          <option value="Small & Medium Enterprises (SMEs)">Small & Medium Enterprises (SMEs)</option>
          <option value="Others">Others</option>
        </select>
      </div>
      
      <div>
        <label class="block text-xs font-label text-gray-400 mb-1">Comment</label>
        <textarea id="page-comment" name="comment" rows="4" placeholder="Tell us about your requirements..." class="w-full bg-[#0e0e0e] border border-white/10 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-[#f9c591] transition-colors"></textarea>
      </div>
      
      <button type="submit" id="submit-inquiry-btn" class="w-full py-4 mt-2 rounded-xl bg-gradient-to-r from-[#f9c591] to-[#e8a86a] text-[#0e0e0e] font-label font-bold text-lg tracking-widest hover:scale-[1.02] transition-transform shadow-lg shadow-[#f9c591]/20 flex justify-center items-center gap-2">
        Submit Inquiry
      </button>

      <div id="page-success-msg" class="hidden text-center text-[#25D366] font-body text-sm mt-4 p-3 bg-[#25D366]/10 rounded-lg border border-[#25D366]/20">
        Thank you! We have received your inquiry. We will contact you soon.
      </div>
      <div id="page-error-msg" class="hidden text-center text-red-500 font-body text-sm mt-4 p-3 bg-red-500/10 rounded-lg border border-red-500/20">
        Failed to submit. Please try again.
      </div>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/modal') %>

<script>
  // Read URL query parameters to auto-fill package and price
  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const pkg = urlParams.get('pkg');
    const price = urlParams.get('price');
    
    if (pkg) document.getElementById('page-package').value = pkg;
    if (price) document.getElementById('page-price').value = price;
  });

  const inquiryForm = document.getElementById('inquiry-form');
  const submitBtn = document.getElementById('submit-inquiry-btn');
  const successMsg = document.getElementById('page-success-msg');
  const errorMsg = document.getElementById('page-error-msg');

  if (inquiryForm) {
    inquiryForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      const originalText = submitBtn.innerHTML;
      submitBtn.innerHTML = 'Submitting...';
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');
      
      const formData = new FormData(inquiryForm);
      const data = Object.fromEntries(formData.entries());
      
      try {
        const response = await fetch('/api/inquiries', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        
        if (response.ok) {
          successMsg.classList.remove('hidden');
          inquiryForm.reset();
        } else {
          errorMsg.classList.remove('hidden');
        }
      } catch (err) {
        console.error(err);
        errorMsg.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });
  }
</script>
<script src="script.js"></script>
</body>
</html>
