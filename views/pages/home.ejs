<!DOCTYPE html>

<html class="dark" lang="en">

<head>
  <%- include('../partials/head') %>
</head>

<body class="bg-[#0e0e0e] text-white font-body selection:bg-primary/30 selection:text-primary overflow-x-hidden">

  <%- include('../partials/header') %>

    <!-- Main Content Canvas -->
    <main class="pt-20 pb-32 px-6 max-w-7xl mx-auto">

      <!-- Hero Section -->
      <header class="mb-32 mt-12 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-6">
          <h1 class="font-body font-extrabold text-5xl md:text-[3.5rem] tracking-tight text-white leading-[1.15]">
            Build a Digital <br /> Product
          </h1>
          <p class="font-body text-gray-400 max-w-md text-[15px] leading-relaxed">
            Turn your vision into reality with innovative websites, apps, and software solutions crafted to accelerate
            your business growth.
          </p>


          <!-- Tiny decorative lightbulb for hero left -->
          <div class="absolute left-10 mt-10 text-[#f9c591]/40">
            <span class="material-symbols-outlined text-2xl">emoji_objects</span>
          </div>
        </div>
        <div class="relative flex justify-center lg:justify-end">
          <!-- Decorative circle/blobs background -->
          <div class="absolute inset-0 bg-[#f9c591]/5 rounded-full blur-3xl transform scale-125 -z-10"></div>

          <!-- Floating blue circles -->
          <div class="absolute -top-4 right-20 w-4 h-4 rounded-full bg-[#d2a373]/80 z-20"></div>
          <div class="absolute bottom-8 -left-4 w-6 h-6 rounded-full bg-[#d2a373]/60 z-20"></div>

          <!-- The main circular masked image container with border -->
          <div
            class="relative w-[320px] h-[320px] md:w-[450px] md:h-[450px] rounded-full p-2 border border-white/10 overflow-visible">
            <div class="w-full h-full rounded-full overflow-hidden relative z-10 border-4 border-[#131313] shadow-2xl">
              <img src="joelx.png" alt="Developer coding" class="w-full h-full object-cover object-center scale-110" />
            </div>

            <!-- Top right orange icon/badge -->
            <div class="absolute -top-2 right-12 z-20 text-[#f9c591]">
              <span class="material-symbols-outlined text-3xl">work</span>
            </div>

            <!-- Top left wave pattern -->
            <div class="absolute top-12 -left-12 z-0 opacity-40">
              <svg width="80" height="80" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <path d="M10,50 Q25,25 50,50 T90,50" fill="none" stroke="#f9c591" stroke-width="2" />
                <path d="M10,60 Q25,35 50,60 T90,60" fill="none" stroke="#f9c591" stroke-width="2" />
                <path d="M10,70 Q25,45 50,70 T90,70" fill="none" stroke="#f9c591" stroke-width="2" />
                <path d="M10,80 Q25,55 50,80 T90,80" fill="none" stroke="#f9c591" stroke-width="2" />
              </svg>
            </div>

            <!-- Bottom right dots grid -->
            <div class="absolute -bottom-8 -right-8 z-0 grid grid-cols-5 gap-3 opacity-40">
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
              <div class="w-1.5 h-1.5 bg-[#f9c591] rounded-full"></div>
            </div>
          </div>
        </div>
      </header>




      <!-- ============================================================
       ABOUT SECTION
       ============================================================ -->
      <section id="about" class="mt-28 max-w-7xl mx-auto">
        <div class="p-10 rounded-2xl bg-[#131313] border border-white/5">
          <h2 class="font-headline italic text-4xl mb-6 text-white">About <span class="text-[#f9c591]">JoelX
              Orbit</span>
          </h2>
          <div class="text-gray-400 leading-relaxed text-[16px] space-y-5">
            <p>
              JoelX Orbit is a forward thinking technology solutions company dedicated to transforming ideas into
              powerful
              digital experiences. We specialize in designing and developing innovative websites, mobile applications,
              desktop software, and business automation systems that help organizations succeed in an increasingly
              digital
              world.
            </p>
            <p>
              Our team combines creativity, technical expertise, and modern development practices to deliver high
              quality
              solutions that are reliable, scalable, and user-friendly. Whether it's a startup looking to establish an
              online presence or an established business seeking advanced digital transformation, JoelX Orbit provides
              tailored solutions designed to meet unique business goals.
            </p>
          </div>
        </div>
      </section>

      <!-- ============================================================
       SERVICES SECTION (Image Layout)
       ============================================================ -->
      <section id="services" aria-label="Our Services" class="mt-32">
        <!-- Section Header -->
        <div class="mb-16 text-center space-y-4">
          <h2 class="font-body font-bold text-4xl text-white">
            Our Services
          </h2>
          <p class="text-gray-400 max-w-2xl mx-auto leading-relaxed text-[15px]">
            Discover a comprehensive range of cutting-edge services tailored to meet your business needs, from web and
            app
            development to IoT and cloud solutions.
          </p>
        </div>

        <!-- Services Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">

          <!-- Web Development Card -->
          <article
            class="bg-[#131313] border border-white/5 rounded-2xl p-8 text-center hover:-translate-y-2 transition-transform duration-300 hover:shadow-[0_10px_40px_rgba(249,197,145,0.05)]">
            <div class="mb-6 inline-flex p-4 rounded-xl bg-[#f9c591]/10">
              <span class="material-symbols-outlined text-[#f9c591] text-4xl">code_blocks</span>
            </div>
            <h4 class="font-body font-bold text-white text-xl mb-4">Web Developement</h4>
            <p class="text-gray-400 text-sm leading-relaxed px-2">
              We specialize in developing responsive and user-centric websites that captivate your audience and drive
              online success.
            </p>
          </article>

          <!-- App Development Card -->
          <article
            class="bg-[#131313] border border-white/5 rounded-2xl p-8 text-center hover:-translate-y-2 transition-transform duration-300 hover:shadow-[0_10px_40px_rgba(249,197,145,0.05)]">
            <div class="mb-6 inline-flex p-4 rounded-xl bg-[#f9c591]/10">
              <span class="material-symbols-outlined text-[#f9c591] text-4xl">phone_iphone</span>
            </div>
            <h4 class="font-body font-bold text-white text-xl mb-4">App Development</h4>
            <p class="text-gray-400 text-sm leading-relaxed px-2">
              From concept to deployment, we transform ideas into powerful and intuitive mobile and web applications
              that
              engage users.
            </p>
          </article>

          <!-- Desktop Application Card -->
          <article
            class="bg-[#131313] border border-white/5 rounded-2xl p-8 text-center hover:-translate-y-2 transition-transform duration-300 hover:shadow-[0_10px_40px_rgba(249,197,145,0.05)]">
            <div class="mb-6 inline-flex p-4 rounded-xl bg-[#f9c591]/10">
              <span class="material-symbols-outlined text-[#f9c591] text-4xl">desktop_windows</span>
            </div>
            <h4 class="font-body font-bold text-white text-xl mb-4">Desktop Application</h4>
            <p class="text-gray-400 text-sm leading-relaxed px-2">
              We build robust, secure, and highly efficient desktop applications using VB.NET, tailored to streamline
              your
              specific business workflows.
            </p>
          </article>

        </div>
      </section>

      <!-- ============================================================
       PRICING SECTION
       ============================================================ -->
      <section id="pricing" class="mt-32">
        <div class="mb-16 text-center space-y-4">
          <div class="flex items-center justify-center gap-3">
            <span class="h-[1px] w-8 bg-[#f9c591]"></span>
            <span class="font-label text-xs uppercase tracking-[0.3em] text-gray-400">Investment</span>
            <span class="h-[1px] w-8 bg-[#f9c591]"></span>
          </div>
          <h2 class="font-headline italic text-4xl md:text-5xl text-white">
            Clear &amp; Transparent <span class="text-[#f9c591]">Pricing.</span>
          </h2>
          <p class="text-gray-400 max-w-2xl mx-auto leading-relaxed">
            Choose a plan that fits your vision. From beautiful static landing pages to fully dynamic digital
            ecosystems,
            we provide exceptional value at every tier.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">

          <!-- Basic Plan -->
          <div class="pricing-card cursor-pointer" onclick="openGetInTouchModal('Basic', '1999')">
            <h3 class="font-headline italic text-2xl text-white mb-2">Basic</h3>
            <div class="mb-6">
              <span class="text-4xl font-bold text-[#f9c591]">₹1999</span>
            </div>
            <div class="space-y-4 mb-8 text-gray-300">
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>Static web site</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>Two pages</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>Default domain</span>
              </div>
            </div>
            <button onclick="openGetInTouchModal('Basic', '1999')"
              class="w-full py-3 rounded-full border border-[#f9c591]/50 text-[#f9c591] font-label font-bold tracking-widest hover:bg-[#f9c591]/10 transition-colors">
              Get Started
            </button>
          </div>

          <!-- Silver Plan (Popular) -->
          <div class="pricing-card popular transform md:-translate-y-4 cursor-pointer"
            onclick="openGetInTouchModal('Silver', '4999')">
            <div
              class="absolute top-0 right-0 bg-gradient-to-r from-[#f9c591] to-[#e8a86a] text-[#0e0e0e] text-[10px] font-bold uppercase tracking-widest px-4 py-1 rounded-bl-xl">
              Most Popular</div>
            <h3 class="font-headline italic text-3xl text-white mb-2">Silver</h3>
            <div class="mb-6">
              <span class="text-5xl font-bold text-[#f9c591]">₹4999</span>
            </div>
            <div class="space-y-4 mb-8 text-gray-300">
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>Static web site</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>SEO integration</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>10 Pages</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>Custom domain</span>
              </div>
            </div>
            <button onclick="openGetInTouchModal('Silver', '4999')"
              class="w-full py-4 rounded-full bg-gradient-to-r from-[#f9c591] to-[#e8a86a] text-[#0e0e0e] font-label font-bold tracking-widest hover:scale-[1.02] transition-transform shadow-lg shadow-[#f9c591]/20">
              Choose Silver
            </button>
          </div>

          <!-- Gold Plan -->
          <div class="pricing-card cursor-pointer" onclick="openGetInTouchModal('Gold', '8999')">
            <h3 class="font-headline italic text-2xl text-white mb-2">Gold</h3>
            <div class="mb-6">
              <span class="text-4xl font-bold text-[#f9c591]">₹8999</span>
            </div>
            <div class="space-y-4 mb-8 text-gray-300">
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>Dynamic web site</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>SEO integration</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>Numbers of pages if need</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>Data Base integration</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>3 Years Support technical</span>
              </div>
              <div class="pricing-feature">
                <span class="material-symbols-outlined text-[#f9c591]">check_circle</span>
                <span>Custom domain</span>
              </div>
            </div>
            <button onclick="openGetInTouchModal('Gold', '8999')"
              class="w-full py-3 rounded-full border border-[#f9c591]/50 text-[#f9c591] font-label font-bold tracking-widest hover:bg-[#f9c591]/10 transition-colors">
              Go Gold
            </button>
          </div>

        </div>
      </section>



      <!-- ============================================================
       TECHNOLOGY STACK SECTION
       ============================================================ -->
      <section id="tech-stack" class="mt-20 mb-16 max-w-7xl mx-auto px-4 md:px-6">
        <div class="mb-20 text-center space-y-4">
          <div class="flex items-center justify-center gap-3">
            <span class="h-[1px] w-8 bg-[#f9c591]"></span>
            <span class="font-label text-xs uppercase tracking-[0.3em] text-gray-400">Expertise</span>
            <span class="h-[1px] w-8 bg-[#f9c591]"></span>
          </div>
          <h2 class="font-headline italic text-4xl text-white">
            Technology <span class="text-[#f9c591]">Stack</span>
          </h2>
          <p class="text-gray-400 max-w-2xl mx-auto leading-relaxed text-[15px]">
            The tools and technologies we use to build robust, scalable, and modern solutions.
          </p>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-x-12 gap-y-16 max-w-5xl mx-auto">

          <!-- Front End Column -->
          <div class="flex flex-col items-center">
            <div
              class="w-16 h-16 rounded-2xl bg-[#131313] border border-[#f9c591]/30 flex items-center justify-center mb-4 text-[#f9c591] shadow-lg shadow-[#f9c591]/10 transform -translate-y-6">
              <span class="material-symbols-outlined text-3xl">devices</span>
            </div>
            <h3 class="text-xl font-body font-bold text-white mb-6">Front End</h3>

            <div class="relative w-full group">
              <div
                class="absolute inset-0 border-t-4 border-l-4 border-[#f9c591] rounded-2xl transform -translate-x-2 -translate-y-2 opacity-80 transition-transform duration-300 group-hover:-translate-x-3 group-hover:-translate-y-3">
              </div>
              <div
                class="relative bg-white border border-gray-200 rounded-2xl py-4 px-6 w-full flex flex-wrap gap-6 justify-center items-center z-10 shadow-2xl transition-all duration-300">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/react/react-original.svg"
                  alt="React"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="React" />
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/flutter/flutter-original.svg"
                  alt="Flutter"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="Flutter" />
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/streamlit/streamlit-original.svg"
                  alt="Streamlit"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="Streamlit" />
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/typescript/typescript-original.svg"
                  alt="TypeScript"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="TypeScript" />
              </div>
            </div>
          </div>

          <!-- Back End Column -->
          <div class="flex flex-col items-center">
            <div
              class="w-16 h-16 rounded-2xl bg-[#131313] border border-[#f9c591]/30 flex items-center justify-center mb-4 text-[#f9c591] shadow-lg shadow-[#f9c591]/10 transform -translate-y-6">
              <span class="material-symbols-outlined text-3xl">code_blocks</span>
            </div>
            <h3 class="text-xl font-body font-bold text-white mb-6">Back End</h3>

            <div class="relative w-full group">
              <div
                class="absolute inset-0 border-t-4 border-l-4 border-[#f9c591] rounded-2xl transform -translate-x-2 -translate-y-2 opacity-80 transition-transform duration-300 group-hover:-translate-x-3 group-hover:-translate-y-3">
              </div>
              <div
                class="relative bg-white border border-gray-200 rounded-2xl py-4 px-6 w-full flex flex-wrap gap-6 justify-center items-center z-10 shadow-2xl transition-all duration-300">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/nodejs/nodejs-original.svg"
                  alt="Node.js"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="Node.js" />
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/dot-net/dot-net-original.svg"
                  alt="ASP.Net"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="ASP.Net" />
                <div
                  class="w-12 h-12 md:w-14 md:h-14 flex items-center justify-center bg-[#5c2d91] text-white transition-transform duration-300 hover:scale-110 rounded-xl shadow-md"
                  title="VB.Net">
                  <span class="font-bold text-base md:text-lg">VB</span>
                </div>
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/express/express-original.svg"
                  alt="Express.js"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="Express.js" />
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/flask/flask-original.svg"
                  alt="Flask"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="Flask" />
              </div>
            </div>
          </div>

          <!-- Database Column -->
          <div class="flex flex-col items-center">
            <div
              class="w-16 h-16 rounded-2xl bg-[#131313] border border-[#f9c591]/30 flex items-center justify-center mb-4 text-[#f9c591] shadow-lg shadow-[#f9c591]/10 transform -translate-y-6">
              <span class="material-symbols-outlined text-3xl">database</span>
            </div>
            <h3 class="text-xl font-body font-bold text-white mb-6">Database</h3>

            <div class="relative w-full group">
              <div
                class="absolute inset-0 border-t-4 border-l-4 border-[#f9c591] rounded-2xl transform -translate-x-2 -translate-y-2 opacity-80 transition-transform duration-300 group-hover:-translate-x-3 group-hover:-translate-y-3">
              </div>
              <div
                class="relative bg-white border border-gray-200 rounded-2xl py-4 px-6 w-full flex flex-wrap gap-6 justify-center items-center z-10 shadow-2xl transition-all duration-300">
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/mysql/mysql-original.svg" alt="SQL"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="SQL" />
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/sqlite/sqlite-original.svg"
                  alt="SQLite"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="SQLite" />
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/mongodb/mongodb-original.svg"
                  alt="MongoDB"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="MongoDB" />
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/firebase/firebase-original.svg"
                  alt="Firebase"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="Firebase" />
              </div>
            </div>
          </div>

          <!-- Server / Cloud Column -->
          <div class="flex flex-col items-center">
            <div
              class="w-16 h-16 rounded-2xl bg-[#131313] border border-[#f9c591]/30 flex items-center justify-center mb-4 text-[#f9c591] shadow-lg shadow-[#f9c591]/10 transform -translate-y-6">
              <span class="material-symbols-outlined text-3xl">dns</span>
            </div>
            <h3 class="text-xl font-body font-bold text-white mb-6">Server</h3>

            <div class="relative w-full group">
              <div
                class="absolute inset-0 border-t-4 border-l-4 border-[#f9c591] rounded-2xl transform -translate-x-2 -translate-y-2 opacity-80 transition-transform duration-300 group-hover:-translate-x-3 group-hover:-translate-y-3">
              </div>
              <div
                class="relative bg-white border border-gray-200 rounded-2xl py-4 px-6 w-full flex flex-wrap gap-6 justify-center items-center z-10 shadow-2xl transition-all duration-300">
                <img
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/amazonwebservices/amazonwebservices-original-wordmark.svg"
                  alt="AWS"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="AWS" />
                <img src="https://cdn.jsdelivr.net/gh/devicons/devicon@2.17.0/icons/vercel/vercel-original.svg"
                  alt="Vercel"
                  class="w-12 h-12 md:w-14 md:h-14 transition-transform duration-300 hover:scale-110 drop-shadow-sm"
                  title="Vercel" />
              </div>
            </div>
          </div>

        </div>
      </section>

    </main>

    <%- include('../partials/footer') %>
      <%- include('../partials/modal') %>
        <script src="/script.js?v=4"></script>
</body>

</html>