<!DOCTYPE html>
<html class="dark" lang="en">

<head>
  <%- include('../partials/head') %>
  <title>Gallery - JoelX Orbit</title>
</head>

<body class="bg-[#0e0e0e] text-white font-body selection:bg-primary/30 selection:text-primary overflow-x-hidden">

  <%- include('../partials/header') %>

  <!-- Main Content Canvas -->
  <main class="pt-32 pb-32 px-6 max-w-7xl mx-auto min-h-screen">

    <div class="mb-16 text-center space-y-4">
      <div class="flex items-center justify-center gap-3">
        <span class="h-[1px] w-8 bg-[#f9c591]"></span>
        <span class="font-label text-xs uppercase tracking-[0.3em] text-gray-400">Our Work</span>
        <span class="h-[1px] w-8 bg-[#f9c591]"></span>
      </div>
      <h1 class="font-headline italic text-4xl md:text-5xl text-white">
        Project <span class="text-[#f9c591]">Gallery.</span>
      </h1>
      <p class="text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Explore our curated collection of digital experiences, applications, and innovative designs.
      </p>
    </div>

    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% if (images && images.length > 0) { %>
        <% images.forEach(function(image) { %>
          <div class="gallery-item cursor-pointer group relative overflow-hidden rounded-2xl bg-[#131313] transition-all duration-500 hover:bg-[#1a1a1a] border border-white/5 hover:border-[#f9c591]/30 hover:shadow-[0_0_30px_rgba(249,197,145,0.1)]" data-src="/assert/gallery image/<%= image.filename %>">
            <div class="aspect-[4/3] overflow-hidden relative">
              <img alt="<%= image.title %>"
                class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
                src="/assert/gallery image/<%= image.filename %>" />
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500">
              </div>
            </div>
            <div
              class="p-6 absolute bottom-0 left-0 w-full z-10 flex flex-col justify-end h-full pointer-events-none">
              <h3
                class="font-headline text-2xl italic text-white group-hover:text-[#f9c591] transition-colors drop-shadow-lg">
                <%= image.title %>
              </h3>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="col-span-full text-center text-gray-500 py-12">
          No images found in the gallery.
        </div>
      <% } %>
    </div>

  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/modal') %>

  <!-- Image Lightbox Modal -->
  <div id="lightbox-modal" class="hidden fixed inset-0 z-[100] bg-black/95 backdrop-blur-md flex items-center justify-center opacity-0 transition-opacity duration-300">
    <button id="lightbox-close" class="absolute top-6 right-6 w-10 h-10 flex items-center justify-center rounded-full bg-white/10 hover:bg-white/20 text-white transition-colors z-[110]">
      <span class="material-symbols-outlined text-xl">close</span>
    </button>
    <div class="relative w-full h-full p-4 flex justify-center items-center pointer-events-none">
      <img id="lightbox-img" src="" alt="Gallery Image" class="max-w-full max-h-[90vh] object-contain rounded-lg shadow-2xl scale-95 transition-transform duration-300 pointer-events-auto" />
    </div>
  </div>

  <script src="/script.js?v=4"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const lightbox = document.getElementById('lightbox-modal');
      const lightboxImg = document.getElementById('lightbox-img');
      const closeBtn = document.getElementById('lightbox-close');
      
      document.querySelectorAll('.gallery-item').forEach(item => {
        item.addEventListener('click', (e) => {
          e.preventDefault();
          const imgSrc = item.getAttribute('data-src');
          if (imgSrc && lightbox && lightboxImg) {
            lightboxImg.src = imgSrc;
            lightbox.classList.remove('hidden');
            setTimeout(() => {
              lightbox.classList.remove('opacity-0');
              lightboxImg.classList.remove('scale-95');
              lightboxImg.classList.add('scale-100');
            }, 10);
            document.body.style.overflow = 'hidden';
          }
        });
      });
      
      const closeLightbox = () => {
        if (lightbox) {
          lightbox.classList.add('opacity-0');
          lightboxImg.classList.remove('scale-100');
          lightboxImg.classList.add('scale-95');
          setTimeout(() => {
            lightbox.classList.add('hidden');
            lightboxImg.src = '';
            document.body.style.overflow = '';
          }, 300);
        }
      };

      if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
      if (lightbox) {
        lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox || e.target.tagName.toLowerCase() === 'div') {
            closeLightbox();
          }
        });
      }
    });
  </script>
</body>

</html>
