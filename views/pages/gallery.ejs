<!DOCTYPE html>
<html class="dark" lang="en">

<head>
  <%- include('../partials/head') %>
    <title>Gallery - JoelX Orbit</title>
</head>

<body class="bg-[#0e0e0e] text-white font-body selection:bg-primary/30 selection:text-primary overflow-x-hidden">

  <%- include('../partials/header') %>

    <!-- Main Content Canvas -->
    <main class="pt-32 pb-32 px-6 max-w-7xl mx-auto min-h-screen">

      <div class="mb-16 text-center space-y-4">
        <div class="flex items-center justify-center gap-3">
          <span class="h-[1px] w-8 bg-[#f9c591]"></span>
          <span class="font-label text-xs uppercase tracking-[0.3em] text-gray-400">Our Work</span>
          <span class="h-[1px] w-8 bg-[#f9c591]"></span>
        </div>
        <h1 class="font-headline italic text-4xl md:text-5xl text-white">
          Project <span class="text-[#f9c591]">Gallery.</span>
        </h1>
        <p class="text-gray-400 max-w-2xl mx-auto leading-relaxed">
          Explore our curated collection of digital experiences, applications, and innovative designs.
        </p>
      </div>

      <!-- Gallery Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% if (images && images.length> 0) { %>
          <% images.forEach(function(image) { %>
            <div
              class="gallery-item cursor-pointer group relative overflow-hidden rounded-2xl bg-[#131313] transition-all duration-500 hover:bg-[#1a1a1a] border border-white/5 hover:border-[#f9c591]/30 hover:shadow-[0_0_30px_rgba(249,197,145,0.1)]"
              data-src="/assert/gallery image/<%= image.filename %>">
              <div class="aspect-[4/3] overflow-hidden relative">
                <img alt="<%= image.title %>"
                  class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
                  src="/assert/gallery image/<%= image.filename %>" />
                <div
                  class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-500">
                </div>
              </div>
              <div
                class="p-6 absolute bottom-0 left-0 w-full z-10 flex flex-col justify-end h-full pointer-events-none">
                <h3
                  class="font-headline text-2xl italic text-white group-hover:text-[#f9c591] transition-colors drop-shadow-lg">
                  <%= image.title %>
                </h3>
              </div>
            </div>
            <% }); %>
              <% } else { %>
                <div class="col-span-full text-center text-gray-500 py-12">
                  No images found in the gallery.
                </div>
                <% } %>
      </div>

      <section id="projects" class="mt-32 mb-16 max-w-7xl mx-auto overflow-hidden">
        <style>
          .project-swiper {
            width: 100%;
            padding-top: 50px;
            padding-bottom: 50px;
          }

          .swiper-slide.project-card {
            background-position: center;
            background-size: cover;
            width: 300px;
            height: 400px;
            border-radius: 20px;
            background-color: #131313;
            overflow: hidden;
            position: relative;
            border: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.5);
          }

          @media (min-width: 768px) {
            .swiper-slide.project-card {
              width: 400px;
              height: 500px;
            }
          }

          .project-img {
            width: 100%;
            height: 100%;
            position: absolute;
            inset: 0;
          }

          .project-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.5;
            transition: all 0.5s ease;
          }

          .swiper-slide-active .project-img img {
            opacity: 0.8;
          }

          .project-img-bg {
            position: absolute;
            inset: 0;
            mix-blend-mode: overlay;
          }

          .project-num {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 3rem;
            font-weight: 800;
            font-family: 'Newsreader', serif;
            font-style: italic;
            color: rgba(255, 255, 255, 0.2);
            z-index: 2;
          }

          .swiper-slide-active .project-num {
            color: rgba(249, 197, 145, 0.6);
          }

          .project-info {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            padding: 30px;
            background: linear-gradient(to top, rgba(14, 14, 14, 1), rgba(14, 14, 14, 0.8), transparent);
            z-index: 4;
            transition: transform 0.5s ease;
          }

          .project-tags {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
          }

          .p-tag {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 4px 10px;
            border-radius: 20px;
            background: rgba(249, 197, 145, 0.1);
            color: #f9c591;
            font-weight: bold;
          }

          .project-name {
            font-family: 'Newsreader', serif;
            font-style: italic;
            font-size: 1.8rem;
            color: #fff;
            margin-bottom: 8px;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
          }

          .project-desc {
            color: #9ca3af;
            font-size: 0.9rem;
            line-height: 1.5;
          }

          .project-overlay {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(2px);
            transition: all 0.4s ease;
            z-index: 5;
          }

          .project-card:hover .project-overlay {
            opacity: 1;
          }

          .overlay-btn {
            padding: 12px 24px;
            background: #f9c591;
            color: #0e0e0e;
            font-weight: bold;
            border-radius: 30px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-size: 0.8rem;
            transform: translateY(20px);
            transition: transform 0.4s ease;
            border: none;
            cursor: pointer;
          }

          .project-card:hover .overlay-btn {
            transform: translateY(0);
          }

          .swiper-pagination-bullet {
            background: #f9c591 !important;
          }
        </style>

